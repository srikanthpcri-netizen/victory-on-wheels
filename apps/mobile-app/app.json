{
  "expo": {
    "name": "Victory On Wheels",
    "slug": "victory-on-wheels-customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "victoryonwheels",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#C90000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.victoryonwheels.customer"
    },
    "android": {
      "package": "com.victoryonwheels.customer",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/app",
      "@react-native-firebase/auth"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "11523c29-5f96-44ea-8506-cb70c48509a7"
      }
    }
  }
}
